# =============================================================================
# RentMaq Pro — .dockerignore
# Basado en .gitignore, adaptado para contexto de Docker build
# =============================================================================

# .NET build artifacts
**/bin/
**/obj/
**/publish/
**/PublishProfiles/

# NuGet
*.nupkg
**/packages/

# IDE
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.csproj.user
*.iml
*.sln.iml

# Angular / Node
**/node_modules/
**/dist/
.angular/
**/out-tsc/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tests & coverage
**/coverage/
**/test-results/
.nyc_output/

# PostgreSQL dumps
*.dump
*.sql.gz
*.pgdump
pg_log/
pg_data/
backups/

# Secrets & env
.env
.env.*
appsettings.Development.json
secrets.json

# Docker (evitar recursión)
**/Dockerfile*
compose.yml
docker-compose*.yml

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Docs y guías (no necesarios en imagen)
docs/
*.md
!src/**/*.md

# Git
.git/
.gitignore
