# =============================================================================
# .NET
# =============================================================================
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.csproj.user

# NuGet
*.nupkg
**/packages/
!**/packages/repositories.config

# Publish output
**/publish/
**/PublishProfiles/

# User secrets & dev settings
appsettings.Development.json
secrets.json

# .NET tool manifests cache
.dotnet/

# =============================================================================
# Angular / Node.js
# =============================================================================
node_modules/
dist/
.angular/
tmp/
out-tsc/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Angular environment overrides (local only)
**/environments/environment.local.ts

# Coverage & test output
coverage/
.nyc_output/
test-results/

# =============================================================================
# PostgreSQL / Base de datos
# =============================================================================
*.dump
*.sql.gz
*.pgdump
pg_log/
pg_data/

# SQL backups generados (NO ignorar migraciones EF ni scripts DDL versionados)
backups/*.sql
*.backup

# =============================================================================
# Variables de entorno y secretos
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml

# =============================================================================
# Logs
# =============================================================================
logs/
*.log

# =============================================================================
# IDE — VS Code
# =============================================================================
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# =============================================================================
# IDE — JetBrains / Rider
# =============================================================================
.idea/
*.sln.iml
*.iml

# =============================================================================
# macOS / Windows / Linux
# =============================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*~

