# =============================================================================
# RentMaq Pro — Variables de Entorno
# Copia este archivo a .env y reemplaza los placeholders con valores reales.
# NUNCA subas .env al repositorio.
# =============================================================================

# --- Base de datos (PostgreSQL 16 + PostGIS 3.4) ---
DB_USER=rentmaq
DB_PASSWORD=devpassword123
DB_NAME=rentmaq_db
DB_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- .NET API ---
ASPNETCORE_ENVIRONMENT=Development

# --- PAC para CFDI 4.0 (solo produccion) ---
# Proveedor: facturapi, sw_sapiens
PAC_PROVIDER=
PAC_API_KEY=

# --- Telemetria AEMP 2.0 ---
# Intervalo de polling a endpoints AEMP de proveedores telematicos (minutos)
AEMP_POLLING_INTERVAL_MINUTES=5
